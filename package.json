{
  "name": "metrologia-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node --use-system-ca ./node_modules/next/dist/bin/next dev",
    "build": "node --use-system-ca ./node_modules/next/dist/bin/next build",
    "start": "node --use-system-ca ./node_modules/next/dist/bin/next start",
    "lint": "node --use-system-ca ./node_modules/next/dist/bin/next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:tdd": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "test:ci": "npm run test && npm run build"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.100.1",
    "motion": "^12.38.0",
    "next": "15.3.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.4",
    "@types/node": "22.14.1",
    "@types/react": "19.0.12",
    "@types/react-dom": "19.0.5",
    "@types/three": "^0.183.1",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "9.23.0",
    "eslint-config-next": "15.3.0",
    "typescript": "5.8.3",
    "vitest": "^4.1.4"
  }
}
